# -------------------------------------------------------------------
# 基础设置
# -------------------------------------------------------------------
port: 7890
socks-port: 7891
allow-lan: true
mode: rule
log-level: info
external-controller: :9090

# -------------------------------------------------------------------
# 代理节点 (此处填入你的自建机场信息)
# -------------------------------------------------------------------
proxies:
  - name: "我的自建节点"
    type: ss  # 或是 vmess, trojan, shadowsocks 等
    server: your.server.com
    port: 443
    cipher: aes-256-gcm
    password: "your_password"
    # udp: true

# -------------------------------------------------------------------
# 策略组 (控制流量走向)
# -------------------------------------------------------------------
proxy-groups:
  - name: 🚀 常用代理
    type: select
    proxies:
      - 我的自建节点
      - DIRECT

  - name: 🍎 苹果服务
    type: select
    proxies:
      - DIRECT
      - 🚀 常用代理

# -------------------------------------------------------------------
# 规则部分 (由上至下执行)
# -------------------------------------------------------------------
rules:
  # --- 自定义例外配置 (单独配置的网址和IP放在最前面) ---
  - DOMAIN-SUFFIX,special-site.com,DIRECT        # 走直连的特定域名
  - DOMAIN,my-api.com,🚀 常用代理                 # 走代理的特定域名
  - IP-CIDR,192.168.1.100/32,DIRECT,no-resolve  # 特定IP走直连

  # --- 常见规则集 ---
  - GEOIP,CN,DIRECT                             # 中国 IP 直连
  - DOMAIN-SUFFIX,cn,DIRECT                     # .cn 域名直连
  - MATCH,🚀 常用代理                            # 其余所有流量走代理

