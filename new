# 1. 找到 rule-providers 这一栏（如果没有，就新建在最顶层）
rule-providers:
  porn_block:
    type: http
    behavior: domain
    url: "https://raw.githubusercontent.com/Loyalsoldier/clash-rules/release/porn.txt"
    path: ./rule_provider/porn_block.yaml
    interval: 86400

# 2. 找到 rules 这一栏，确保拦截规则在最上方
rules:
  # --- 屏蔽色情网站开始 ---
  - RULE-SET,porn_block,REJECT
  # 如果想通过关键词拦截（慎用，可能会误伤，如 search?q=sex）
  - DOMAIN-KEYWORD,porn,REJECT
  - DOMAIN-KEYWORD,sex,REJECT
  - DOMAIN-KEYWORD,adult,REJECT
  # --- 屏蔽色情网站结束 ---

  # 下面是你原本的规则，例如：
  - GEOIP,CN,DIRECT
  - MATCH,Proxy
